<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <!-- Config Store bootstrappes via environmentvariablen AZURE_APPCONFIG_CONNECTIONSTRING. -->
    <add key="UseConfigStore" value="true" />
    <add key="LocalOverrideFile" value="appsettings.local.json" />
    <add key="Mode" value="DRYRUN" />
    <add key="EnableLocalDebugLogging" value="false" />
    <add key="LocalDebugLogPath" value="" />
    <add key="MutexName" value="dk.gi.app.konto.afslutarealsager" />
    <add key="modtagereEmail" value="fallback@gi.dk" />
    <add key="SecondsToSleep" value="45" />
    <add key="MaxWaitCount" value="15" />
    <add key="TimeOutMinutter" value="2" />
    <add key="reuseserviceclient" value="true" />
    <add key="CrmAuthorityMode" value="AsConfigured" />
    <add key="OpfoelgesFraPlusDage" value="5" />
    <add key="TilladSendTilDigitalPost" value="false" />
    <add key="AllowPartialRun" value="false" />
    <add key="EnableCloseoutQueueRun" value="false" />
    <add key="EnableDirectIncidentCloseoutRun" value="false" />
    <add key="EnableCarryForwardArealRun" value="false" />
    <add key="EnableDeleteZeroRegnskabRun" value="false" />
    <add key="EnableArealSumQueueRun" value="false" />
    <add key="DirectIncidentCloseStatusCode" value="5" />
    <add key="ForceIncidentId" value="" />
    <add key="ForceSagsnummer" value="" />
    <add key="ForceKontonr" value="" />
    <!-- Bevidst blanke/defaultbare værdier. Forventes normalt fra App Configuration eller lokal override. -->
    <add key="CrmConnectionTemplate" value="" />
    <add key="CrmServerName" value="" />
    <add key="CrmClientId" value="" />
    <add key="CrmClientSecret" value="" />
    <add key="CrmAuthority" value="" />
    <add key="BrugerArealSager" value="" />
  </appSettings>
</configuration>
