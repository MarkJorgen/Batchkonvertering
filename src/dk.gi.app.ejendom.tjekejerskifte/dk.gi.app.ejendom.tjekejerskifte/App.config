<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <add key="UseConfigStore" value="true" />
    <add key="LocalOverrideFile" value="appsettings.local.json" />
    <add key="Mode" value="DRYRUN" />
    <add key="EnableLocalDebugLogging" value="false" />
    <add key="LocalDebugLogPath" value="" />
    <add key="MutexName" value="dk.gi.app.ejendom.tjekejerskifte" />
    <add key="modtagereEmail" value="fallback@gi.dk" />
    <add key="SecondsToSleep" value="25" />
    <add key="MaxWaitCount" value="5" />
    <add key="TimeOutMinutter" value="2" />
    <add key="reuseserviceclient" value="true" />
    <add key="MaxDage" value="30" />
    <add key="MaxAntal" value="1000" />
    <add key="ServiceBusQueueName" value="crmpluginjobs" />
    <add key="ServiceBusLabel" value="TINGLYSNINGDATO" />
    <add key="QueueScheduleStepSeconds" value="15" />
  </appSettings>
</configuration>
