<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <appSettings>
    <add key="UseConfigStore" value="true" />
    <add key="LocalOverrideFile" value="appsettings.local.json" />
    <add key="Mode" value="DRYRUN" />
    <add key="EnableLocalDebugLogging" value="false" />
    <add key="LocalDebugLogPath" value="" />
    <add key="MutexName" value="dk.gi.app.konto.kontoejerLuk" />
    <add key="modtagereEmail" value="fallback@gi.dk" />
    <add key="SecondsToSleep" value="45" />
    <add key="MaxWaitCount" value="15" />
    <add key="TimeOutMinutter" value="2" />
    <add key="reuseserviceclient" value="true" />
  </appSettings>
</configuration>
