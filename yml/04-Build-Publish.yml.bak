# Pipeline is only triggered manually
# trigger: none
trigger:
  branches:
    include:
      - develop

parameters:
  - name: azureSubscription
    default: 'GIAzureDev'
    displayName: Azure service connection, Vælg "GIAzureDEV" eller "GIAzureTST" eller "GIAzurePRD"
    type: string
    values:
      - 'GIAzureDev'
      - 'GIAzureTST'
      - 'GIAzurePRD'

  - name: PackageName
    default: 'dk.gi.crm.app.faelles.cprvalidering'
    displayName: Name of the package to build
    type: string

  - name: PackageFolder
    default: 'src/dk.gi.app.cprvalidering'
    displayName: Name of the package folder to build
    type: string

  # - name: envName
  #   default: 'dev'
  #   displayName: Which environment to deploy to
  #   values:
  #     - 'dev'
  #     - 'tst'
  #     - 'prd'

  - name: solution
    default: 'dk.gi.crm.app.faelles.cprvalidering.sln'
    displayName: Visual Studio solution/projekt, der skal bygges
    type: string

  - name: debug
    default: 'false'
    displayName: 'Debug build?'
    type: boolean

name: Batch jobs deployment pipeline

# Defining necessary variables
variables:
  location: 'westeurope'
  environmentName: 'dev'
  resourceGroupName: 'gif-dev-app-batch'
  WebAppName: 'gif-batch-app'
  azurewebjobpackage: $(PackageName)
  WebjobName: 'CprValidering'
  buildPlatform: 'AnyCPU'
  buildConfiguration: 'debug'

resources:
  repositories:
  - repository: SourceRepo
    type: git
    name: App/dk.gi.app.cprvalidering
  - repository: MainRepo
    type: git
    name: App/App
    ref: develop

pool:
  vmImage: 'windows-latest'

# Starting the job
stages:
- stage: 'DEV'
  displayName: 'Job-Deployment'
  jobs:
  - job: 'Build'
    steps: 
    - checkout: SourceRepo
    - task: VSBuild@1
      displayName: 'Build Assembly $(azurewebjobpackage)'
      inputs:
        solution: '$(Pipeline.Workspace)/s/$(PackageFolder)/$(solution)'
        msbuildArgs: '/t:build /p:DeployOnBuild=true /p:SkipInvalidConfigurations=true /p:OutputPath="$(Build.ArtifactStagingDirectory)\$(PackageName)"'
        configuration: '$(buildConfiguration)'
        platform: '$(buildPlatform)'
        # - task: NuGetCommand@2
        #   displayName: 'NuGet pack build to Artifact Staging Directory'
